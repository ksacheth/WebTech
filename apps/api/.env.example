# Environment variables for apps/api
# Copy this to .env and fill in the values.

# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database — must match the DATABASE_URL in packages/database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lab_proctor_db?schema=public"

# Auth (add secret when implementing JWT)
# JWT_SECRET=change_me
